# Supabase — Settings > API Keys in your Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Storage — "r2" for Cloudflare R2 (or any S3-compatible provider), or "local" for self-hosting with no cloud account
STORAGE_PROVIDER=r2
STORAGE_BUCKET=potluck-photos
STORAGE_ACCOUNT_ID=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=

# Email invites (optional) — without these, invites fall back to copy-link + QR.
# Get a key at resend.com; INVITE_FROM_EMAIL must be a verified sender/domain.
RESEND_API_KEY=
INVITE_FROM_EMAIL=
